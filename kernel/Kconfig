menu "Kernel Features"

config FRAMEBUFFER
	bool "Framebuffer console"
	default y
	help
	  Enable the graphical framebuffer console.
	  If disabled, output goes to serial only.

config SSE
	bool "Enable SSE support"
	default y
	help
	  Enable SSE/SSE2 in the kernel for user programs.

config SWAP
	bool "Enable swap support (ZRAM + disk)"
	default y
	help
	  Cooperative page reclaim via ZRAM (compressed RAM) and
	  optional disk swap (tail-of-ATA-disk).  When enabled,
	  PMM OOM triggers swap_try_reclaim() before giving up.

config ZRAM
	bool "Enable ZRAM (compressed RAM swap)"
	default y
	depends on SWAP
	help
	  Compress reclaimable pages into kernel heap using LZO.
	  Works even without a disk.  Effective for mostly-zero pages.

config DEMAND_PAGING
	bool "Enable demand paging"
	default y
	depends on SWAP
	help
	  Defer physical frame allocation until a page is first accessed.
	  ELF segments, anonymous mmap, and brk pages are all mapped as
	  not-present demand PTEs.  A page fault allocates and populates
	  the frame on first touch.  Significantly reduces startup memory
	  usage and makes large-binary loading nearly instantaneous.
	  Requires CONFIG_SWAP for the unified fault handler path.

config INITRD
	bool "Load initrd from Limine module"
	default y
	help
	  Extract a cpio initrd archive at boot and populate ramfs.

config VERBOSE_SYSCALL
	bool "Verbose syscall logging"
	default n
	help
	  Log warnings for unimplemented and out-of-bounds syscalls.
	  Useful for debugging, noisy in production.

menu "Kernel log levels"

config KLOG_SHOW_EMERG
	bool "Show EMERG messages"
	default y

config KLOG_SHOW_ERR
	bool "Show ERR messages"
	default y

config KLOG_SHOW_WARN
	bool "Show WARN messages"
	default y

config KLOG_SHOW_INFO
	bool "Show INFO messages"
	default y

config KLOG_SHOW_DEBUG
	bool "Show DEBUG messages"
	default n

endmenu

endmenu
