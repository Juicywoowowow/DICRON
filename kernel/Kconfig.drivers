menu "Drivers"

config SERIAL
	bool "Serial port (COM1)"
	default y

config PS2_KBD
	bool "PS/2 keyboard"
	default y

config PIT
	bool "PIT timer"
	default y

config EXT2
	bool "ext2 filesystem driver"
	default y
	help
	  Read-write ext2 filesystem support.

config EXT2_CHECK
	bool "ext2 integrity checks"
	default y
	depends on EXT2
	help
	  Run validation checks on superblocks, inodes, and directories
	  during mount and I/O. Slight performance cost but catches
	  corruption early.

config EXT2_SYNC
	bool "ext2 sync/flush support"
	default y
	depends on EXT2
	help
	  Dirty tracking and metadata flush on sync/unmount.
	  Ensures writes are persisted and clean unmount state is set.

config RAMDISK
	bool "RAM block device"
	default y
	help
	  Memory-backed block device for loading filesystem images.

config PCI
	bool "PCI bus enumeration"
	default y
	help
	  Scan and enumerate PCI devices at boot.
	  Required for AHCI, NIC, and most modern hardware.

endmenu

menu "New Drivers"

comment "Functional but subject to change — enable individually"

config HPET
	bool "HPET timer"
	default n
	help
	  High Precision Event Timer (HPET) support. Includes nanosecond 
	  timing API. Replaces the PIT timer.

menu "ATA / Disk"

config ATA
	bool "ATA PIO disk driver"
	default n
	help
	  ATA PIO-mode disk driver for IDE hard drives.
	  Required for persistent storage on real or emulated hardware.

config ATA_PRIMARY
	bool "Probe primary ATA bus (0x1F0)"
	default y
	depends on ATA

config ATA_SECONDARY
	bool "Probe secondary ATA bus (0x170)"
	default n
	depends on ATA

config PARTITION_MBR
	bool "MBR partition table support"
	default y
	depends on ATA
	help
	  Parse MBR partition tables to find ext2 partitions on disk.

config TEST_ATA_DRIVE
	bool "Create temporary test ATA drive for QEMU"
	default n
	depends on ATA
	help
	  When enabled, the QEMU run targets will automatically create
	  a small raw disk image, attach it as a secondary IDE drive,
	  and delete it when QEMU exits. Useful for testing ATA and
	  partition code against a real (emulated) disk.

endmenu

endmenu

menu "Staged Drivers"

comment "Experimental / unstable — disabled by default"

endmenu
